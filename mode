#!/usr/bin/env bash

MODE="$1"

if [ -z "$MODE" ]; then
  echo "Usage: ./mode <exploring|casting|overseeing|build>"
  exit 1
fi

# Validate against known keys
case "$MODE" in
  exploring|casting|overseeing|build|greenfielding|brownfielding) ;;
  *)
    echo "Unknown mode \"$MODE\". Valid options: exploring, casting, overseeing, build"
    exit 1
    ;;
esac

RESPONSE=$(curl -s -o /dev/null -w "%{http_code}" \
  -X POST \
  -H "Content-Type: application/json" \
  -d "{\"mode\":\"$MODE\"}" \
  http://localhost:3000/api/agent-mode)

if [ "$RESPONSE" = "200" ]; then
  echo "Mode updated to: $MODE"
else
  echo "Failed to update mode (HTTP $RESPONSE). Is the agent running on :3000?"
  exit 1
fi
